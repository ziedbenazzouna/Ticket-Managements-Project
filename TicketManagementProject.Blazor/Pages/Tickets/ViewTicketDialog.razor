@using TicketManagementProject.Blazor.Enum
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Assignment" Class="mr-3 mb-n1" />
            Consultation Ticket #@model.Id?.Substring(0, 5)...
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudField Label="Objet de l'intervention" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Topic">
                    @model.Objet
                </MudField>
            </MudItem>

            <MudItem xs="6">
                <MudField Label="Auteur" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person">
                    @model.Auteur
                </MudField>
            </MudItem>

            <MudItem xs="6">
                <MudField Label="Date de création" Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.CalendarToday">
                    @model.Date.ToShortDateString()
                </MudField>
            </MudItem>

            <MudItem xs="6">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Catégorie</MudText>
                <div class="d-flex align-center mt-1">
                    <MudIcon Icon="@Icons.Material.Filled.Category" Class="mr-2" Color="Color.Default" />
                    <MudText Typo="Typo.body1">@model.CategorieEnum.ToString().Replace("_", " ")</MudText>
                </div>
            </MudItem>

            <MudItem xs="6">
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Statut Actuel</MudText>
                <div class="mt-1">
                    <MudChip T="string" Color="@model.StatutEnum.GetColor()" Variant="Variant.Filled" Size="Size.Small">
                        @model.StatutEnum
                    </MudChip>
                </div>
            </MudItem>

            <!-- SECTION COMMENTAIRES (Bas) -->
            <MudItem xs="12">
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle1"><b>Commentaires (@(model.Commentaires?.Count ?? 0))</b></MudText>

                <!-- Zone d'affichage des commentaires existants -->
                <div style="max-height: 200px; overflow-y: auto;" class="mt-2 px-2">
                    @if (model.Commentaires == null || !model.Commentaires.Any())
                    {
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Aucun commentaire pour le moment.</MudText>
                    }
                    else
                    {
                        @foreach (var comment in model.Commentaires.OrderByDescending(c => c.Date))
                        {
                            <div class="mb-2 pa-2 mud-bg-gray-lighter rounded">
                                <div class="d-flex justify-space-between">
                                    <MudText Typo="Typo.caption" Color="Color.Primary"><b>@comment.Auteur</b></MudText>
                                    <MudText Typo="Typo.caption">@comment.Date.ToString("g")</MudText>
                                </div>
                                <MudText Typo="Typo.body2">@comment.Message</MudText>
                            </div>
                        }
                    }
                </div>

                <!-- Zone de saisie Nouveau Commentaire -->
                @if (model.StatutEnum != StatutIntervention.Closed)
                {
                    <div class="d-flex align-end mt-4">
                        <MudTextField @bind-Value="_newCommentMessage"
                                      Label="Ajouter un commentaire..."
                                      Variant="Variant.Text"
                                      Lines="1"
                                      Class="flex-grow-1" />
                        <MudIconButton Icon="@Icons.Material.Filled.Send"
                                       Color="Color.Primary"
                                       OnClick="AjouterCommentaire"
                                       Disabled="@string.IsNullOrWhiteSpace(_newCommentMessage)" />
                    </div>
                }
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        @if (model.StatutEnum != StatutIntervention.Closed)
        {
            <MudButton Variant="Variant.Filled"
                       Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       OnClick="CloturerTicket"
                       Class="px-6">
                Clôturer
            </MudButton>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Default" OnClick="Cancel" Class="px-10">Fermer</MudButton>
    </DialogActions>
</MudDialog>