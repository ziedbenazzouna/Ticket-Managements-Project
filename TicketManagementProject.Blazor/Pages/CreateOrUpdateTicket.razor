@using TicketManagementProject.Blazor.Enum

<EditForm Model="@model" OnValidSubmit="OnValidSubmit">
    <MudDialog>
        <DialogContent>
            <DataAnnotationsValidator />
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField Variant="Variant.Outlined" Label="Objet" @bind-Value="model.Objet" For="@(() => model.Objet)" />
                </MudItem>

                <MudItem xs="6">
                    <MudTextField Variant="Variant.Outlined" Label="Auteur" @bind-Value="model.Auteur" For="@(() => model.Auteur)" />
                </MudItem>

                <MudItem xs="6">
                    <MudDatePicker Variant="Variant.Outlined" Label="Date" @bind-Date="_date" />
                </MudItem>

                <MudItem xs="6">
                    <MudSelect T="CategorieIntervention" Label="Catégorie" Variant="Variant.Outlined" @bind-Value="model.CategorieEnum" AnchorOrigin="Origin.BottomCenter">
                        @foreach (CategorieIntervention item in Enum.GetValues(typeof(CategorieIntervention)))
                        {
                            <MudSelectItem Value="@item">@item.ToString().Replace("_", " ")</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6">
                    <MudSelect T="StatutIntervention" Label="Statut" Variant="Variant.Outlined" @bind-Value="model.StatutEnum" AnchorOrigin="Origin.BottomCenter">
                        @foreach (StatutIntervention item in Enum.GetValues(typeof(StatutIntervention)))
                        {
                            <MudSelectItem Value="@item">@item.ToString()</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </DialogContent>
        <DialogActions>
            <MudButton Color="Color.Default" OnClick="Cancel">Annuler</MudButton>
            <MudButton ButtonType="ButtonType.Submit" Color="Color.Primary" Variant="Variant.Filled">Enregistrer</MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>
